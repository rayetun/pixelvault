# Files and folders that should NOT be deployed to the WordPress.org plugin SVN.
# The 10up deploy action excludes everything listed here from trunk/tags.

# Version control & CI
.git
.github
.gitignore
.gitattributes
.distignore

# WordPress.org listing assets (handled by the asset-update workflow, not shipped in the plugin)
.wordpress-org

# Local / OS / editor cruft
.DS_Store
Thumbs.db
.idea
.vscode
*.log

# Build & dependency tooling (not used at runtime)
node_modules
package.json
package-lock.json
composer.json
composer.lock
phpcs.xml
phpcs.xml.dist
.phpcs.xml.dist
phpunit.xml
phpunit.xml.dist
tests
bin

# Distribution artifacts
pixelvault.zip
